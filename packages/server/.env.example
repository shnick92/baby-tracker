# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tracker:tracker@localhost:5432/tracker

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-32-chars-minimum-random
JWT_REFRESH_SECRET=change-me-32-chars-minimum-random

# ─── Push Notifications (VAPID) ──────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your@email.com

# ─── SOS Alert (Twilio voice call fallback) ───────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ─── Seed users ───────────────────────────────────────────────────────────────
SEED_USER_1_NAME=Parent1
SEED_USER_1_EMAIL=parent1@example.com
SEED_USER_1_PASSWORD=changeme
SEED_USER_1_PHONE=+1xxxxxxxxxx

SEED_USER_2_NAME=Parent2
SEED_USER_2_EMAIL=parent2@example.com
SEED_USER_2_PASSWORD=changeme
SEED_USER_2_PHONE=+1xxxxxxxxxx

# ─── App config ───────────────────────────────────────────────────────────────
APP_URL=https://your-tailscale-hostname
FAMILY_NAME=Baby Tracker
TIMEZONE=America/Chicago
CLIENT_ORIGIN=http://localhost:5173

# ─── Anthropic / AI ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# AI_ENABLED — master kill switch for all AI routes. Set to "false" to disable
# all Anthropic API calls without removing the key. Default: true (enabled when
# ANTHROPIC_API_KEY is set).
AI_ENABLED=true

# AI_DAILY_CALL_LIMIT — maximum Anthropic API calls per calendar day across all
# routes (PARSE, INSIGHTS, CHAT, WEEKLY). Returns HTTP 429 when exceeded.
# Default: 200.
AI_DAILY_CALL_LIMIT=200

# AI_DAILY_COST_ALERT_USD — if estimated daily spend exceeds this amount, a
# socket event (alert:ai-cost) is emitted at 11 PM so a banner appears in-app.
# Default: 1.00 (USD).
AI_DAILY_COST_ALERT_USD=1.00

# SEED_DATA_GUARD — set to "true" during development seeding sessions to prevent
# accidental real Anthropic API calls. All AI routes return stubs. The weekly
# cron summary is also suppressed. Default: false.
SEED_DATA_GUARD=false
