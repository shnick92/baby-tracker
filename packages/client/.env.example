VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_VAPID_PUBLIC_KEY=<generate with: npx web-push generate-vapid-keys>

# Family surname shown in the Baby Names full-name preview (e.g. "Emma Grace Stone").
# Leave unset or empty to omit the surname from the preview.
VITE_FAMILY_SURNAME=

# Canonical URL for purchase shortlinks.
# Set to your publicly accessible server URL (Tailscale hostname, Cloudflare Tunnel, etc.).
# When set, the shortlink copy button (🔗) appears on purchase items.
# When unset, only the copy-original-URL button (📋) is shown — which always works without
# any server access and is sufficient for sharing with friends/family.
VITE_APP_URL=
