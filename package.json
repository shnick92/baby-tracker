{
  "name": "tracker",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint \"packages/**/*.{ts,tsx,js,mjs}\"",
    "test": "npm test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev": "concurrently -n server,client \"npm run dev -w packages/server\" \"npm run dev -w packages/client\"",
    "prepare": "husky",
    "screenshots": "npx tsx scripts/screenshots.ts",
    "screenshots:gifs": "bash scripts/make-gifs.sh",
    "screenshots:all": "npm run screenshots && npm run screenshots:gifs"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx,js,mjs}": "eslint --max-warnings 0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "~15.5.0",
    "playwright": "^1.60.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.19.1"
  },
  "engines": {
    "node": ">=20"
  }
}
