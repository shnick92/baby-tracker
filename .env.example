# ─── Server ───────────────────────────────────────────────
DATABASE_URL=postgresql://tracker:tracker@localhost:5432/tracker

JWT_ACCESS_SECRET=change-me-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-at-least-32-chars-long

ANTHROPIC_API_KEY=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your@email.com

# App config (used in display; change per family)
FAMILY_NAME=Baby Tracker
ADMIN_EMAIL=your@email.com
MAX_USERS=2
TIMEZONE=America/Chicago
APP_URL=https://your-tailscale-hostname

PORT=3001

# ─── Seed users (run `npx prisma db seed` after setting these) ────
SEED_USER_1_NAME=Nick
SEED_USER_1_EMAIL=nick@example.com
SEED_USER_1_PASSWORD=changeme

SEED_USER_2_NAME=Jess
SEED_USER_2_EMAIL=jess@example.com
SEED_USER_2_PASSWORD=changeme

# ─── Emergency SOS — Twilio (optional for Android-only; required for iOS SOS) ─
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
NICK_PHONE_NUMBER=+1xxxxxxxxxx
JESS_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Client (prefix all with VITE_) ──────────────────────
# Copy this block to packages/client/.env
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_VAPID_PUBLIC_KEY=
