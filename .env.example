# ─── Server (packages/server/.env) ───────────────────────
DATABASE_URL=postgresql://tracker:tracker@localhost:5432/tracker

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change-me-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-at-least-32-chars-long

# Express CORS — set to your Tailscale hostname in production
CLIENT_ORIGIN=http://localhost:5173

NODE_ENV=development
PORT=3001

# WebAuthn / Passkeys
# RP_ID must be the hostname only (no port, no protocol)
# RP_ORIGIN must be the full origin the browser sees (protocol + host + port if non-standard)
# In dev: RP_ID=localhost, RP_ORIGIN=http://localhost:5173
# In prod: RP_ID=<tailscale-hostname>, RP_ORIGIN=http://<tailscale-hostname>
RP_ID=localhost
RP_NAME=Baby Tracker
RP_ORIGIN=http://localhost:5173

ANTHROPIC_API_KEY=

# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your@email.com

# App config (used in display; change per family)
FAMILY_NAME=Baby Tracker
ADMIN_EMAIL=your@email.com
MAX_USERS=2
TIMEZONE=America/Chicago
APP_URL=https://your-tailscale-hostname

# ─── Seed users (run `npx prisma db seed` after setting these) ────
SEED_USER_1_NAME=Nick
SEED_USER_1_EMAIL=nick@example.com
SEED_USER_1_PASSWORD=changeme

SEED_USER_2_NAME=Jess
SEED_USER_2_EMAIL=jess@example.com
SEED_USER_2_PASSWORD=changeme

# ─── Emergency SOS — Twilio (optional for Android-only; required for iOS SOS) ─
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
NICK_PHONE_NUMBER=+1xxxxxxxxxx
JESS_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Client (packages/client/.env) ───────────────────────
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
# Same value as VAPID_PUBLIC_KEY above
VITE_VAPID_PUBLIC_KEY=

# ─── Production Docker (docker/docker-compose.prod.yml) ───
DOCKERHUB_USERNAME=
POSTGRES_PASSWORD=tracker
POSTGRES_USER=tracker
POSTGRES_DB=tracker

# Tailscale IPv4 address of this machine (run `tailscale ip -4` to get it).
# Scopes nginx port bindings to the Tailscale interface only, avoiding
# conflicts with Unraid's own nginx which holds 127.0.0.1:443.
TAILSCALE_IP=100.x.x.x
